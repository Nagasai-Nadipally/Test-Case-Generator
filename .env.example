# Copy this file to .env (or export these as real environment variables)
# and fill in your free Groq API key from https://console.groq.com/keys
#
# Spring AI reads these via spring.ai.openai.* in application.yml.

GROQ_API_KEY=gsk_your_key_here

# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
#
# base-url must NOT include /v1 - Spring AI appends /v1/chat/completions itself.
# GROQ_BASE_URL=https://api.groq.com/openai
